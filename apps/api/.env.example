# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://HiveMind:password@db:5432/HiveMind

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://hivemind.marvinlerouge.local

# ─── Seed admin user ───────────────────────────────────────────────────────────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@HiveMind.local
SEED_ADMIN_PASSWORD=change_me_admin

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
# Required for invitation emails. Without these, POST /collections/:id/invitations returns 502.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_IGNORE_TLS=false
SMTP_USER=no-reply@example.com
SMTP_PASS=change_me_smtp
SMTP_FROM="HiveMind <no-reply@example.com>"
FRONTEND_BASE_URL=http://hivemind.marvinlerouge.local
